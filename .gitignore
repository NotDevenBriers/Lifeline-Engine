# ---------------------------------------------------------
temp/
tmp/
cache/
Cache/
logs/
Logs/

# ---------------------------------------------------------
# Shader Cache
# ---------------------------------------------------------
shadercache/
ShaderCache/

# ---------------------------------------------------------
# Asset Pipeline Generated Files
