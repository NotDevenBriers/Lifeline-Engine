# =========================================================
# C++ Game Engine .gitignore
# Covers:
# - CMake
# - Visual Studio
# - VSCode
# - CLion / JetBrains
# - GCC / Clang
# - Build outputs
# - Common engine temp/cache files
# =========================================================

# ---------------------------------------------------------
# Build Directories
# ---------------------------------------------------------
build/
Build/
bin/
Bin/
out/
Out/
dist/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/

# ---------------------------------------------------------
# CMake
# ---------------------------------------------------------
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
Testing/
Makefile
install_manifest.txt

# ---------------------------------------------------------
# Ninja
# ---------------------------------------------------------
.ninja_deps
.ninja_log
build.ninja

# ---------------------------------------------------------
# Visual Studio
# ---------------------------------------------------------
.vs/
*.VC.db
*.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates
*.ilk
*.pdb
*.idb
*.ipch
*.obj
*.pch
*.aps
*.ncb
*.opendb

# ---------------------------------------------------------
# VSCode
# ---------------------------------------------------------
.vscode/

# ---------------------------------------------------------
# CLion / JetBrains
# ---------------------------------------------------------
.idea/
cmake-build-*/

# ---------------------------------------------------------
# macOS
# ---------------------------------------------------------
.DS_Store

# ---------------------------------------------------------
